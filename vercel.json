{
  "version": 2,
  "builds": [
    {
      "src": "frontend/vite.config.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!admin).*)",
      "destination": "/frontend/dist/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin-panel/dist/index.html"
    }
  ]
}